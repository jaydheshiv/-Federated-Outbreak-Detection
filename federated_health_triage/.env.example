# Groq API Configuration (ChatGPT Clinical Advisor)
# ==================================================
# Get your FREE API key from: https://console.groq.com
#
# Groq offers free tier with excellent speed and good token limits
# Model: llama-3.3-70b-versatile (70B parameter open-source LLM)
# Perfect for healthcare decision support and fast inference

# Your Groq API Key (REQUIRED for AI features)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model selection (available Groq models)
# llama-3.3-70b-versatile: Best for clinical guidance (DEFAULT)
# mixtral-8x7b-32768: Fast alternative
# gemma-7b-it: Lightweight option
GROQ_MODEL=llama-3.3-70b-versatile

# Enable/Disable Groq AI features
# true: Use Groq LLM for clinical insights and recommendations
# false: Use local ML only (no external API calls)
ENABLE_GROQ_AI=true

# System Configuration
# ====================
SAMPLE_SIZE=1000
MODEL_TYPE=random_forest
AGGREGATION_METHOD=weighted_avg

# Output Configuration
# ====================
RESULTS_DIR=results
VISUALIZATIONS_DIR=results/visualizations
LOG_LEVEL=INFO
